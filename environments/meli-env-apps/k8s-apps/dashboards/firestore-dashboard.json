{
  "uid": "firestore-native-dynamic-clean",
  "title": "Firestore Native Dashboard",
  "schemaVersion": 36,
  "version": 28,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "refresh": "1m",
  "templating": {
    "list": [
      {
        "name": "project_id",
        "label": "GCP Project",
        "type": "query",
        "datasource": "Google Cloud Monitoring",
        "definition": "label_values(firestore.googleapis.com/api/request_count, resource.label.project_id)",
        "query": "label_values(firestore.googleapis.com/api/request_count, resource.label.project_id)",
        "refresh": 1,
        "includeAll": false,
        "multi": false,
        "hide": 0,
        "sort": 1,
        "description": "Select the Google Cloud Project"
      },
      {
        "name": "database_id",
        "label": "Database ID",
        "type": "query",
        "datasource": "Google Cloud Monitoring",
        "definition": "label_values(firestore.googleapis.com/api/request_count, resource.label.database_id)",
        "query": "label_values(firestore.googleapis.com/api/request_count, resource.label.database_id)",
        "refresh": 1,
        "includeAll": false,
        "multi": false,
        "hide": 0,
        "sort": 1,
        "description": "Select the Firestore Database"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "API Requests (Target: $database_id)",
      "description": "Metric: api/request_count",
      "type": "timeseries",
      "datasource": "Google Cloud Monitoring",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "axisLabel": "Requests/sec", "lineWidth": 2 }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "metrics",
          "projectName": "$project_id",
          "service": "firestore.googleapis.com",
          "metricType": "firestore.googleapis.com/api/request_count",
          "crossSeriesReducer": "REDUCE_SUM",
          "perSeriesAligner": "ALIGN_RATE",
          "alignmentPeriod": "60s",
          "groupBys": ["metric.label.method"],
          "filters": [
            "resource.label.project_id", "=", "$project_id",
            "AND",
            "resource.label.database_id", "=", "$database_id"
          ],
          "aliasBy": "{{metric.label.method}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Storage Size (Target: $database_id)",
      "description": "Metric: data_and_index_storage_bytes",
      "type": "timeseries",
      "datasource": "Google Cloud Monitoring",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "color": { "mode": "palette-classic" },
          "custom": { "axisLabel": "Bytes", "fillOpacity": 20 }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "metrics",
          "projectName": "$project_id",
          "service": "firestore.googleapis.com",
          "metricType": "firestore.googleapis.com/storage/data_and_index_storage_bytes",
          "crossSeriesReducer": "REDUCE_SUM",
          "perSeriesAligner": "ALIGN_MEAN",
          "alignmentPeriod": "60s",
          "filters": [
            "resource.label.project_id", "=", "$project_id",
            "AND",
            "resource.label.database_id", "=", "$database_id"
          ],
          "aliasBy": "Storage Used"
        }
      ]
    },
    {
      "id": 3,
      "title": "Request Latency (Target: $database_id)",
      "description": "Metric: api/request_latencies (p99, p95, p50, p05)",
      "type": "timeseries",
      "datasource": "Google Cloud Monitoring",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "axisLabel": "Seconds", "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "A" },
            "properties": [ { "id": "displayName", "value": "p99 (Worst 1%)" } ]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [ { "id": "displayName", "value": "p95 (Standard)" } ]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "C" },
            "properties": [ { "id": "displayName", "value": "p50 (Median)" } ]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "D" },
            "properties": [ { "id": "displayName", "value": "p05 (Fastest 5%)" } ]
          }
        ]
      },
      "options": {
        "legend": {
          "calcs": ["last"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "metrics",
          "projectName": "$project_id",
          "service": "firestore.googleapis.com",
          "metricType": "firestore.googleapis.com/api/request_latencies",
          "crossSeriesReducer": "REDUCE_PERCENTILE_99",
          "perSeriesAligner": "ALIGN_DELTA",
          "alignmentPeriod": "60s",
          "filters": [
            "resource.label.project_id", "=", "$project_id",
            "AND",
            "resource.label.database_id", "=", "$database_id"
          ]
        },
        {
          "refId": "B",
          "queryType": "metrics",
          "projectName": "$project_id",
          "service": "firestore.googleapis.com",
          "metricType": "firestore.googleapis.com/api/request_latencies",
          "crossSeriesReducer": "REDUCE_PERCENTILE_95",
          "perSeriesAligner": "ALIGN_DELTA",
          "alignmentPeriod": "60s",
          "filters": [
            "resource.label.project_id", "=", "$project_id",
            "AND",
            "resource.label.database_id", "=", "$database_id"
          ]
        },
        {
          "refId": "C",
          "queryType": "metrics",
          "projectName": "$project_id",
          "service": "firestore.googleapis.com",
          "metricType": "firestore.googleapis.com/api/request_latencies",
          "crossSeriesReducer": "REDUCE_PERCENTILE_50",
          "perSeriesAligner": "ALIGN_DELTA",
          "alignmentPeriod": "60s",
          "filters": [
            "resource.label.project_id", "=", "$project_id",
            "AND",
            "resource.label.database_id", "=", "$database_id"
          ]
        },
        {
          "refId": "D",
          "queryType": "metrics",
          "projectName": "$project_id",
          "service": "firestore.googleapis.com",
          "metricType": "firestore.googleapis.com/api/request_latencies",
          "crossSeriesReducer": "REDUCE_PERCENTILE_05",
          "perSeriesAligner": "ALIGN_DELTA",
          "alignmentPeriod": "60s",
          "filters": [
            "resource.label.project_id", "=", "$project_id",
            "AND",
            "resource.label.database_id", "=", "$database_id"
          ]
        }
      ]
    },
    {
      "id": 4,
      "title": "Billable Reads (Target: $database_id)",
      "description": "Metric: billable_read_units",
      "type": "timeseries",
      "datasource": "Google Cloud Monitoring",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "axisLabel": "Units" }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "metrics",
          "projectName": "$project_id",
          "service": "firestore.googleapis.com",
          "metricType": "firestore.googleapis.com/api/billable_read_units",
          "crossSeriesReducer": "REDUCE_SUM",
          "perSeriesAligner": "ALIGN_RATE",
          "alignmentPeriod": "60s",
          "filters": [
            "resource.label.project_id", "=", "$project_id",
            "AND",
            "resource.label.database_id", "=", "$database_id"
          ],
          "aliasBy": "Billable Reads"
        }
      ]
    },
    {
      "id": 5,
      "title": "Billable Writes (Target: $database_id)",
      "description": "Metric: billable_write_units",
      "type": "timeseries",
      "datasource": "Google Cloud Monitoring",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "axisLabel": "Units" }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "metrics",
          "projectName": "$project_id",
          "service": "firestore.googleapis.com",
          "metricType": "firestore.googleapis.com/api/billable_write_units",
          "crossSeriesReducer": "REDUCE_SUM",
          "perSeriesAligner": "ALIGN_RATE",
          "alignmentPeriod": "60s",
          "filters": [
            "resource.label.project_id", "=", "$project_id",
            "AND",
            "resource.label.database_id", "=", "$database_id"
          ],
          "aliasBy": "Billable Writes"
        }
      ]
    }
  ]
}